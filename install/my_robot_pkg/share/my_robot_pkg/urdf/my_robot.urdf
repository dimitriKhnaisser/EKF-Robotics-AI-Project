<?xml version="1.0"?>
<robot name="tricycle_robot">

  <!-- ================= BASE ================= -->
  <link name="base_link">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.05" ixy="0.0" ixz="0.0"
               iyy="0.05" iyz="0.0"
               izz="0.05"/>
    </inertial>

    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.3 0.2 0.1"/>
      </geometry>
    </collision>

    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.3 0.2 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <!-- ================= IMU ================= -->
  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0"
               iyy="1e-6" iyz="0"
               izz="1e-6"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.08"/>
  </joint>

  <!-- ================= FRONT STEERING ================= -->
  <link name="front_steer_link"/>

  <joint name="steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_steer_link"/>
    <origin xyz="0.18 0 -0.02"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6" upper="0.6" effort="10" velocity="1"/>
  </joint>

  <!-- ================= FRONT WHEEL (FIXED VISIBILITY) ================= -->
  <link name="front_wheel">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>

    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.04"/>
      </geometry>
    </collision>

    <visual>
      <!-- ROTATE CYLINDER TO LOOK LIKE WHEEL -->
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.04"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="front_wheel_joint" type="continuous">
    <parent link="front_steer_link"/>
    <child link="front_wheel"/>
    <origin xyz="0 0 -0.08"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= REAR BALL LEFT ================= -->
  <link name="rear_left_ball">
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0005" ixy="0" ixz="0"
               iyy="0.0005" iyz="0"
               izz="0.0005"/>
    </inertial>

    <collision>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>

    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="orange">
        <color rgba="1 0.5 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="rear_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_left_ball"/>
    <origin xyz="-0.12 0.08 -0.05"/>
  </joint>

  <!-- ================= REAR BALL RIGHT ================= -->
  <link name="rear_right_ball">
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0005" ixy="0" ixz="0"
               iyy="0.0005" iyz="0"
               izz="0.0005"/>
    </inertial>

    <collision>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>

    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="orange">
        <color rgba="1 0.5 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="rear_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_right_ball"/>
    <origin xyz="-0.12 -0.08 -0.05"/>
  </joint>

  <!-- ================= IMU SENSOR ================= -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>50</update_rate>

      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <frame_name>imu_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ================= PLANAR MOVE ================= -->
  <gazebo>
    <plugin name="planar_move" filename="libgazebo_ros_planar_move.so">
      <ros>
        <namespace>/</namespace>
      </ros>

      <cmd_vel_topic>cmd_vel</cmd_vel_topic>
      <odom_topic>odom</odom_topic>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>

      <robot_base_frame>base_link</robot_base_frame>
      <odometry_frame>odom</odometry_frame>
    </plugin>
  </gazebo>
  <gazebo reference="base_link">
  <plugin name="ground_truth" filename="libgazebo_ros_p3d.so">
    <ros>
      <namespace>/</namespace>
    </ros>
    <update_rate>50.0</update_rate>
    <body_name>base_link</body_name>
    <frame_name>world</frame_name>
  </plugin>
</gazebo>
</robot>